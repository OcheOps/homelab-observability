# ============================================================
# homelab-observability environment config
# Copy this to .env and fill in your values
# ============================================================

# --- Cloudflare Tunnel ---
# Your existing tunnel UUID (find with: cloudflared tunnel list)
CF_TUNNEL_UUID=YOUR_TUNNEL_UUID_HERE

# Path to your tunnel credentials JSON inside the container
# This maps to ./cloudflared/credentials.json on the host
CF_TUNNEL_CREDS=/etc/cloudflared/credentials.json

# --- Grafana ---
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme_grafana_password
GF_SERVER_ROOT_URL=https://grafana.monitor.ocheverse.ng
GF_SERVER_DOMAIN=grafana.monitor.ocheverse.ng

# --- ntopng ---
NTOPNG_PASSWORD=changeme_ntopng_password

# --- Throttle Engine ---
THROTTLE_LISTEN_ADDR=:8090
THROTTLE_LOG_LEVEL=info
# Bandwidth threshold in bytes/sec before alerting (default 100MB/s)
THROTTLE_BW_THRESHOLD=104857600

# --- Network Interface ---
# The main network interface to monitor (run `ip link` to find yours)
HOST_NETWORK_INTERFACE=eno1
